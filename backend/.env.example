# ═══════════════════════════════════════════════════════════════
# Ziyo Scanner — Backend Environment Variables
# Copy this file to .env and adjust values if needed
# ═══════════════════════════════════════════════════════════════

# App mode: "local" = local-first (runs on your machine)
APP_MODE=local

# Django
DJANGO_SECRET_KEY=local-dev-key-change-if-needed
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis (runs in Docker)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Scanner service (runs in Docker)
SCANNER_SERVICE_URL=http://scanner:8001

# Domain Reputation (optional — get free API keys)
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=
DOMAIN_REPUTATION_CACHE_HOURS=24

# PostgreSQL (optional — uncomment to use instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/wscaner
